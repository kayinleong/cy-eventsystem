rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // D-13: inventory item photos — admin-only write, signed-in read.
    // T-02-02-11 (anonymous photo bucket browse) mitigation.
    // T-02-02-12 (non-image upload + DoS) mitigation: 5MB + content-type.
    match /items/{itemId}/photo.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny-by-default for any other path under the bucket.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
