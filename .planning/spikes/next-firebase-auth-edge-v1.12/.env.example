# .env.example — TEMPLATE for the values that must live in `.env.local` at repo
# root for the spike (and the rest of Phase 2) to function.
#
# DO NOT commit `.env.local` itself — it is gitignored (`.env*` rule). Copy this
# file's CONTENT into a new `.env.local` and fill in the placeholders.
#
# Three credentials sources are needed:
#   1. Firebase Console → Project Settings → General → "Your apps" → Web app
#      config (the 5 NEXT_PUBLIC_* keys).
#   2. Service account JSON (already at `./sa.json` in repo root; gitignored)
#      — either extract two fields by hand OR (recommended) use the
#      GOOGLE_APPLICATION_CREDENTIALS path option (see below).
#   3. Random cookie signature keys generated with `openssl rand -base64 32`.
#      The spike orchestrator pre-generates these for you and surfaces them in
#      the checkpoint message — paste those values here.

# =====================================================================
# 1. Firebase Web SDK config (public — safe to ship to the browser)
# =====================================================================
# Source: Firebase Console → Project Settings → General → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=<API_KEY>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<PROJECT_ID>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<PROJECT_ID>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<PROJECT_ID>.firebasestorage.app
NEXT_PUBLIC_FIREBASE_APP_ID=<APP_ID>

# =====================================================================
# 2. Firebase Admin SDK credentials (server-only — NEVER ship to browser)
# =====================================================================
# Choose ONE of the two options below. Option A is recommended (less error-prone).

# ---- Option A (RECOMMENDED): GOOGLE_APPLICATION_CREDENTIALS path ----
#
# Point Admin SDK at the service-account JSON file directly. firebase-admin
# auto-detects this env var when `cert(...)` is not passed an explicit
# credentials object. Avoids manual private-key escaping pitfalls.
#
# If you choose Option A, UNCOMMENT the next line and DELETE the three
# FIREBASE_* env vars in Option B below.
#
# GOOGLE_APPLICATION_CREDENTIALS=./sa.json
#
# Note: `next-firebase-auth-edge` v1.12 does NOT auto-detect
# GOOGLE_APPLICATION_CREDENTIALS — its `serviceAccount: {...}` option requires
# an explicit object. The spike's `proxy.spike.ts` passes the three FIREBASE_*
# env vars directly. Therefore Option A alone is INSUFFICIENT for the spike;
# you must also set FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL +
# FIREBASE_PRIVATE_KEY (Option B). Option A is only useful for places that use
# raw Admin SDK without auth-edge (e.g., verify-session.spike.ts could be
# adapted; the seed-first-admin script in 02-04).

# ---- Option B: Inline credentials (REQUIRED for auth-edge spike) ----
#
# Extract the two values from sa.json. The private key value is a multi-line
# PEM block — wrap it in double-quotes and KEEP the literal `\n` sequences
# (do NOT replace them with real newlines in the .env file; the code does
# `replace(/\\n/g, "\n")` at read time per Firebase Admin SDK convention).
#
# Example (placeholders only — paste your real values):
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvg...lots-of-base64...\n-----END PRIVATE KEY-----\n"

FIREBASE_PROJECT_ID=<PROJECT_ID>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-<HASH>@<PROJECT_ID>.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="<PRIVATE_KEY_PEM_BLOCK_WITH_LITERAL_BACKSLASH_N>"

# =====================================================================
# 3. Cookie signature keys (32+ random bytes each, base64-encoded)
# =====================================================================
# next-firebase-auth-edge signs the __session cookie with these keys. Rotate
# CURRENT → PREVIOUS at every rotation; both must be valid for grace-period
# verification.
#
# Generate locally:
#   openssl rand -base64 32
# (run twice — values MUST differ)
#
# The spike orchestrator pre-generates these and shows them in the checkpoint
# message — copy those values here. NEVER commit them to git.

AUTH_COOKIE_SIGNATURE_KEY_CURRENT=<base64-32-bytes-current>
AUTH_COOKIE_SIGNATURE_KEY_PREVIOUS=<base64-32-bytes-previous-different>

# =====================================================================
# 4. Misc
# =====================================================================
# Set to `true` only on HTTPS deployments. Spike runs on localhost over HTTP,
# so this MUST be `false` or the browser will refuse to set the cookie.
USE_SECURE_COOKIES=false

# Public app URL — used by /set-password and password-reset email actionCode
# settings (D-07/D-08, plan 02-04). Spike doesn't need it but Phase 2 does.
NEXT_PUBLIC_APP_URL=http://localhost:3000
