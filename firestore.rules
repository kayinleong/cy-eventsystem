rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      // Two paths to "admin":
      //   (a) The ID token carries role=admin custom claim (set by Cloud
      //       Function 1 on users/{uid} writes — propagates within ~1h or
      //       on getIdToken(true)).
      //   (b) Fallback: the Firestore users/{uid} doc says role=admin.
      // The fallback handles the window where claims haven't propagated to
      // the Web SDK's token yet but the doc has been authoritatively written.
      // Cost: ≤1 extra doc read per evaluation, only when token path misses.
      return isSignedIn() && (
        request.auth.token.role == 'admin'
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function isMember(eventDoc) {
      return isSignedIn() && (
        isAdmin()
        || request.auth.uid in eventDoc.data.allowedStaff
      );
    }
    function untouched(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == resource.data[field];
    }

    // -------- users (UA-01..06) --------
    match /users/{uid} {
      // Any signed-in user can read their own doc; admins can read any.
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Block ALL client writes. Cloud Function 1 (Admin SDK) and
      // Server Actions are the only writers — both bypass rules.
      // T-02-02-09 (elevation of privilege) mitigation.
      allow create, update, delete: if false;
    }

    // -------- inventory (INV-01..05, INT-02) --------
    match /inventory/{itemId} {
      // Explicit get + list split: in some Firestore SDK versions the
      // collection-list query evaluator is stricter about `read` than the
      // single-doc evaluator. Splitting makes the intent unambiguous —
      // both operations require only that the requester be authenticated.
      allow get, list: if isSignedIn();
      // Admin-only create/delete; admin-only update with invariant.
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.availableQty is number
        && request.resource.data.availableQty >= 0
        && request.resource.data.availableQty <= request.resource.data.totalQty;
    }

    // -------- deliveryOrders (quick-kayinleong-001) --------
    // Admin-only create via Server Action; immutable in v1 (no update / delete).
    // Any signed-in user can read so staff can follow an item back to its DO.
    match /deliveryOrders/{doId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // -------- events (EVT-01..09) --------
    match /events/{eventId} {
      allow read: if isSignedIn() && isMember(resource);
      // EVT-01: admin OR team lead can create — narrower check in Server Action.
      allow create: if isSignedIn();
      // Admin OR team lead can edit; allowedStaff is server-managed
      // (Cloud Function 2) so clients cannot mutate it (T-02-02-07).
      allow update: if (isAdmin() || request.auth.uid in resource.data.teamLeads)
        && untouched('allowedStaff');
      allow delete: if isAdmin();
    }

    // -------- transactions (immutable, server-only writes — INT-03, AUD-04) --------
    match /transactions/{txId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    // -------- missingItems (server-only writes — MIS-01..04) --------
    match /missingItems/{missingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    // -------- catch-all deny-by-default (D-06 mitigation a) --------
    // Anything not explicitly allowed above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
